# Prisma Postgres connection (provisioned in CON-6 / M0-2).
# The app and ingestion read/write through this. Prisma Postgres provides a
# pooled connection string; bulk ingestion may use the direct string.
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=YOUR_KEY"

# Canonical wiki source, used for ingestion and for attribution deep-links.
CONCORD_WIKI_BASE_URL="https://wiki.concordlarp.com"

# Upstash Redis for per-IP rate limiting (CON-11 / M3, CON-12 / M4).
# Leave blank in local dev to disable rate limiting.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
